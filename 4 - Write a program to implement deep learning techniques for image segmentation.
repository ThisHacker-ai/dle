from tensorflow.keras.datasets import mnist
import numpy as np
import matplotlib.pyplot as plt

(xtrain, _), (xtest, _) = mnist.load_data()

#img = xtest[0]
for i in range(0,3):
  img = xtest[i]
  mask = img>100

  plt.subplot(3,2,i * 2 + 1)
  plt.title("Original")
  plt.imshow(img, cmap="gray")

  plt.subplot(3,2,i * 2 + 2)
  plt.title("Segmented")
  plt.imshow(mask, cmap="gray")

plt.show()
